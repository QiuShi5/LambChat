{
  "version": "0.3.0",
  "app": {
    "name": "Data Transform"
  },
  "workflow": {
    "graph": {
      "nodes": [
        { "id": "start", "data": { "type": "start", "title": "Start" } },
        {
          "id": "transform",
          "data": {
            "type": "data-transform",
            "title": "Render summary",
            "template": "Summary for {{name}}",
            "output_key": "summary"
          }
        },
        {
          "id": "answer",
          "data": {
            "type": "answer",
            "title": "Answer",
            "answer": "{{summary}}"
          }
        }
      ],
      "edges": [
        { "id": "e1", "source": "start", "target": "transform" },
        { "id": "e2", "source": "transform", "target": "answer" }
      ]
    }
  }
}
