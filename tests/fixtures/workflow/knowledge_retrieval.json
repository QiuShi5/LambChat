{
  "version": "0.3.0",
  "app": {
    "name": "Knowledge Retrieval"
  },
  "workflow": {
    "nodes": [
      { "id": "start", "type": "start", "data": { "title": "Start" } },
      {
        "id": "knowledge",
        "type": "knowledge-retrieval",
        "data": {
          "title": "Search Knowledge",
          "dataset_ids": ["dataset-1"]
        }
      },
      { "id": "answer", "type": "answer", "data": { "title": "Answer", "answer": "{{knowledge.result}}" } }
    ],
    "edges": [
      { "id": "e1", "source": "start", "target": "knowledge" },
      { "id": "e2", "source": "knowledge", "target": "answer" }
    ]
  }
}
