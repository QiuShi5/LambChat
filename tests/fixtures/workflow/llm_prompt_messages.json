{
  "version": "0.3.0",
  "app": {
    "name": "LLM Prompt Messages"
  },
  "workflow": {
    "graph": {
      "nodes": [
        { "id": "start", "data": { "type": "start", "title": "Start" } },
        {
          "id": "llm",
          "data": {
            "type": "llm",
            "title": "Chat Prompt",
            "model": { "provider": "openai", "name": "gpt-4o-mini" },
            "prompt_template": [
              { "name": "system", "text": "You are concise." },
              { "name": "user", "template": "Question: {{message}}" },
              { "name": "assistant", "promptTemplate": "Ready." }
            ]
          }
        },
        { "id": "answer", "data": { "type": "answer", "title": "Answer", "answer": "{{llm_text}}" } }
      ],
      "edges": [
        { "id": "e1", "source": "start", "target": "llm" },
        { "id": "e2", "source": "llm", "target": "answer" }
      ]
    }
  }
}
