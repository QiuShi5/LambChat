{
  "version": "0.3.0",
  "app": {
    "name": "LLM Message Parts"
  },
  "workflow": {
    "graph": {
      "nodes": [
        { "id": "start", "data": { "type": "start", "title": "Start" } },
        {
          "id": "llm",
          "data": {
            "type": "llm",
            "title": "Message Parts",
            "model": { "provider": "openai", "name": "gpt-4o-mini" },
            "messages": [
              {
                "role": "user",
                "content": [
                  { "type": "text", "text": "Question: {{message}}" },
                  "\nContext: ",
                  { "type": "input_text", "content": "{{context}}" },
                  { "type": "image", "url": "https://example.invalid/image.png" }
                ]
              },
              {
                "role": "assistant",
                "content": { "type": "markdown", "data": "Ready." }
              }
            ]
          }
        },
        { "id": "answer", "data": { "type": "answer", "title": "Answer", "answer": "{{llm_text}}" } }
      ],
      "edges": [
        { "id": "e1", "source": "start", "target": "llm" },
        { "id": "e2", "source": "llm", "target": "answer" }
      ]
    }
  }
}
