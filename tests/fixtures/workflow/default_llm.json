{
  "version": "0.3.0",
  "app": {
    "name": "Default LLM"
  },
  "workflow": {
    "graph": {
      "nodes": [
        {
          "id": "start",
          "data": {
            "type": "start",
            "title": "Start"
          }
        },
        {
          "id": "llm",
          "data": {
            "type": "llm",
            "title": "Use Default Model",
            "prompt_template": "Answer briefly: {{#sys.query#}}",
            "model_parameters": {
              "max_tokens": 64
            }
          }
        },
        {
          "id": "answer",
          "data": {
            "type": "answer",
            "title": "Answer",
            "answer": "{{llm_text}}"
          }
        }
      ],
      "edges": [
        { "id": "e1", "source": "start", "target": "llm" },
        { "id": "e2", "source": "llm", "target": "answer" }
      ]
    }
  }
}
